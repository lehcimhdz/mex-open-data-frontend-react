{
  "name": "mex-open-data-frontend-react",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "React frontend that consumes mex-open-data-backend-fastapi to surface every dataset published on datos.gob.mx.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
